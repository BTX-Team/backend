server:
  port: 8080

spring:
  # DevTools
  devtools:
    livereload:
      enabled: true
    restart:
      enabled: true

  # DataSource (MySQL - AWS RDS)
  datasource:
    url: jdbc:mysql://b2x-db.c18usww0m79e.ap-northeast-2.rds.amazonaws.com:3306/b2x?useSSL=true&serverTimezone=Asia/Seoul
    username: admin
    password: YOUR_PASSWORD_HERE
    driver-class-name: com.mysql.cj.jdbc.Driver
    hikari:
      max-lifetime: 1800000
      keepalive-time: 60000

  # JPA
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect
    open-in-view: false

  # Multipart
  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 20MB

# JWT
jwt:
  secret: your-256-bit-secret-key-here-change-this-to-your-own-secret-key-at-least-32-characters
  access-token-validity: 1800000
  refresh-token-validity: 604800000

# File Upload Paths
file:
  profile:
    web-path: /images/profile/
    folder-path: C:/uploadFiles/profile/
  board:
    web-path: /images/board/
    folder-path: C:/uploadFiles/board/

# Swagger
springdoc:
  swagger-ui:
    path: /swagger-ui.html
    tags-sorter: alpha
    operations-sorter: alpha
  api-docs:
    path: /v3/api-docs

# Logging
logging:
  level:
    com.b2x: DEBUG
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql.BasicBinder: TRACE
